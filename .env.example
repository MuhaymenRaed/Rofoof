# Supabase — copy to .env.local and fill in.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Server-only. Bypasses RLS — never expose to the browser or commit.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# WhatsApp number used at checkout (digits only, country code first)
NEXT_PUBLIC_WHATSAPP_NUMBER=9647735473375

# Store's Instagram profile, linked from the footer
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/rofoof.iq/

# Telegram order-alert bot. Server-only — get the token from @BotFather and
# the chat ID from @userinfobot (or the getUpdates API).
TELEGRAM_BOT_TOKEN=<bot-token>
TELEGRAM_CHAT_ID=<chat-id>
